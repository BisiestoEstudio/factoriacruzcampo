{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/custom-title",
	"version": "0.1.0",
	"title": "Título personalizado",
	"category": "bisiesto",
	"icon": {
		"src": "heading",
		"foreground": "#7900D8"
	},
	"description": "Título con embellecedor o con antetítulo",
	"example": {},
	"attributes": {
		"variation": {
			"type": "string",
			"enum": ["embellecedor", "antetitulo"],
			"default": "embellecedor"
		},
		"title": {
			"type": "string",
			"default": ""
		},
		"antetitulo": {
			"type": "string",
			"default": ""
		},
		"anchor": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"background": false,
			"text": false
		}
	},
	"textdomain": "factoria-cruzcampo-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
