{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/spacer",
	"version": "0.1.0",
	"title": "Espaciador Responsive",
	"category": "bisiesto",
	"icon": {
		"src": "editor-expand",
		"foreground": "#7900D8"
	},
	"description": "Espaciador responsive",
	"example": {},
	"attributes": {
		"heightMobile": {
			"type": "number",
			"default": "0"
		},
		"heightDesktop": {
			"type": "number",
			"default": "0"
		}
	},
	"supports": {
		"html": false,
		"anchor": false,
		"className": false,
		"align": false
	},
	"textdomain": "unico-blocks",
	"editorStyle": "file:./index.css",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}