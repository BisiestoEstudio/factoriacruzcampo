{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/experience-cards",
	"version": "0.1.0",
	"title": "Experience Cards",
	"category": "bisiesto",
	"icon": {
		"src": "star-filled",
		"foreground": "#7900D8"
	},
	"description": "Grid de experiencias filtrable por clasificación",
	"example": {},
	"parent": ["bisiesto/section","bisiesto/scroll-over"],
	"attributes": {
		"anchor": { "type": "string", "default": "" },
		"mode": { "type": "string", "default": "category" },
		"clasification": { "type": "string", "default": "all" },
		"selectedIds": { "type": "array", "items": { "type": "integer" }, "default": [] }
	},
	"styles": [
		{
			"name": "grid",
			"label": "Grid",
			"isDefault": true
		},
		{
			"name": "4-columns",
			"label": "4 columnas"
		},
		{
			"name": "3-columns",
			"label": "3 columnas"
		},
		{
			"name": "2-columns",
			"label": "2 columnas"
		}
	],
	"supports": {
		"html": false,
		"anchor": true,
		"align": false,
		"color": {
			"background": false,
			"text": false
		}
	},
	"textdomain": "factoria-cruzcampo-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
