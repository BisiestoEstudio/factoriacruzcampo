{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/background-shape",
	"version": "0.1.0",
	"title": "Background Shape",
	"category": "bisiesto",
	"icon": { "src": "format-image", "foreground": "#7900D8" },
	"description": "Imagen decorativa posicionada en el fondo de un section",
	"parent": [ "bisiesto/section" ],
	"example": {},
	"attributes": {
		"imageId": { "type": "number", "default": 0 },
		"width": { "type": "string", "default": "" },
		"maxWidth": { "type": "string", "default": "" },
		"maxHeight": { "type": "string", "default": "" },
		"anchor": { "type": "string", "default": "top-left" },
		"offsetX": { "type": "object", "default": { "value": 0, "unit": "px" } },
		"offsetY": { "type": "object", "default": { "value": 0, "unit": "px" } },
		"rotation": { "type": "number", "default": 0 }
	},
	"supports": {
		"html": false,
		"anchor": false,
		"align": false,
		"spacing": false,
		"color": false
	},
	"textdomain": "factoria-cruzcampo-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
